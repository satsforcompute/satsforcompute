{
  "app_name": "satsforcompute",
  "github_release": {
    "repo": "satsforcompute/satsforcompute",
    "asset": "satsforcompute"
  },
  "cmd": ["/var/lib/easyenclave/bin/satsforcompute"],
  "env": [
    "SATS_PORT=8090",
    "SATS_STATE_REPO=${SATS_STATE_REPO}",
    "SATS_CODE_REPO=satsforcompute/satsforcompute",
    "SATS_DD_CP_URL=https://app.devopsdefender.com",
    "SATS_SWEEP_ADDRESS=${SATS_SWEEP_ADDRESS}",
    "SATS_GITHUB_TOKEN=${SATS_GITHUB_TOKEN}",
    "SATS_TOOL_API_TOKEN=${SATS_TOOL_API_TOKEN}",
    "SATS_OPS_REPO=${SATS_OPS_REPO}",
    "SATS_PRICE_PER_24H_SATS=50000",
    "SATS_PENDING_TIMEOUT_SECS=10800",
    "RUST_LOG=satsforcompute=info"
  ],
  "expose": { "hostname_label": "bot", "port": 8090 }
}
